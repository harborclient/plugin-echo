{
  "name": "@harborclient/plugin-echo",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "build": "pnpm build:main && pnpm build:renderer",
    "build:main": "esbuild src/main.ts --bundle --outfile=dist/main.js --format=esm --platform=neutral",
    "build:renderer": "node scripts/esbuild-renderer.mjs && node scripts/validate-renderer.mjs",
    "dev": "pnpm dev:main & pnpm dev:renderer",
    "dev:main": "esbuild src/main.ts --bundle --outfile=dist/main.js --format=esm --platform=neutral --watch",
    "dev:renderer": "node scripts/esbuild-renderer.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack": "pnpm build && zip -r echo.hcp manifest.json README.md dist",
    "plugin:sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "plugin:verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "esbuild": "^0.25.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0"
  }
}
